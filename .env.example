# ------------------------------------------------------------------------------
# Production Environment Variables Config (.env)
# ------------------------------------------------------------------------------
# Keep this file out of version control (add .env to .gitignore).
# This file is used for deploying to AWS EC2 + RDS or Render.

# 1. Spring Profile
# Set to 'prod' to activate application-prod.yml
SPRING_PROFILES_ACTIVE=prod

# 2. Database Connection (PostgreSQL)
# Format: jdbc:postgresql://<host>:<port>/<database_name>
# For AWS RDS: Replace <host> with your RDS endpoint (e.g., mydb.xxx.region.rds.amazonaws.com)
# For Render: Replace <host> with your internal Render DB URL
DB_URL=jdbc:postgresql://<your_rds_or_render_host>:5432/ticket_booking

# Database Credentials
DB_USERNAME=postgres
DB_PASSWORD=your_secure_db_password

# 3. Application Security
# Generate a strong, random 64-character hex string for the JWT secret in production.
# DO NOT use the default development key in production!
JWT_SECRET=your_super_secret_64_character_hex_string_for_production_jwt

# 4. Server Port (Optional)
# Default is 8080. If Render assigns a specific port, it will inject the PORT variable automatically.
PORT=8080
